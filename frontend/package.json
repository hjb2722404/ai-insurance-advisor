{
  "name": "ai-insurance-advisor-frontend",
  "version": "1.0.0",
  "description": "AI-powered insurance advisor web application with uni-app framework",
  "scripts": {
    "dev:h5": "uni build --watch --mode development --platform h5",
    "dev:mp-weixin": "uni build --watch --mode development --platform mp-weixin",
    "build:h5": "uni build --mode production --platform h5",
    "build:mp-weixin": "uni build --mode production --platform mp-weixin",
    "type-check": "vue-tsc --noEmit",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4020920240930001",
    "@dcloudio/uni-app-plus": "3.0.0-4020920240930001",
    "@dcloudio/uni-components": "3.0.0-4020920240930001",
    "@dcloudio/uni-h5": "3.0.0-4020920240930001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4020920240930001",
    "pinia": "^2.1.7",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4020920240930001",
    "@dcloudio/uni-cli-shared": "3.0.0-4020920240930001",
    "@dcloudio/uni-vite-plugin": "3.0.0-4020920240930001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4020920240930001",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.11.24",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.5.1",
    "@vitest/ui": "^1.0.0",
    "jsdom": "^23.0.0",
    "typescript": "^5.3.3",
    "vite": "5.1.4",
    "vitest": "^1.0.0",
    "vue-tsc": "^2.0.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
