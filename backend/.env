# AI Service Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: Custom API base URL (defaults to https://api.openai.com/v1)
# OPENAI_API_BASE_URL=

# Optional: Model to use for consultations (defaults to gpt-4o-mini)
# OPENAI_CONSULTATION_MODEL=gpt-4o-mini

# Optional: Model to use for contract interpretation (defaults to gpt-4o-mini)
# OPENAI_INTERPRETATION_MODEL=gpt-4o-mini

# Application Configuration
# Environment: development, staging, production
APP_ENV=development

# API Configuration
# Backend API host (defaults to 0.0.0.0)
API_HOST=0.0.0.0

# Backend API port (defaults to 8000)
API_PORT=8001

# CORS Configuration
# Frontend origin to allow (defaults to http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Optional: Additional allowed origins (comma-separated)
# ADDITIONAL_ALLOWED_ORIGINS=

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: Enable request logging for debugging
# DEBUG_REQUESTS=false

# File Upload Configuration
# Max file size for PDF uploads in bytes (defaults to 10MB)
# MAX_FILE_SIZE=10485760

# Allowed file extensions for upload (comma-separated)
# ALLOWED_EXTENSIONS=.pdf

# Rate Limiting (Optional - if implemented)
# REQUESTS_PER_MINUTE=60
# BURST_SIZE=10
